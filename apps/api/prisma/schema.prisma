generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Comment {
  id String @id @default(uuid())

  name    String
  message String

  status CommentStatus

  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?
  shownAt      DateTime?
  rejectReason String?
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SHOWN
}
